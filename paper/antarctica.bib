@article{Angel1970,
  title = {Urban {{Velocity Fields}}},
  author = {Angel, S. and Hyman, G.M.},
  year = 1970,
  month = jun,
  journal = {Environment and Planning A: Economy and Space},
  volume = {2},
  number = {2},
  pages = {211--224},
  issn = {0308-518X},
  doi = {10.1068/a020211},
  urldate = {2024-09-09},
  abstract = {The city is not an undifferentiated terrain and travel does not occur along straight-line paths at constant velocities. Variations in travel velocities at different locations bend the minimum time paths away from regions of high congestion. This paper discusses a transformation of the urban plane into a time surface on which distance corresponds to travel time, and describes the construction of minimum paths and isochrones for various velocity fields. This view of the urban transportation system allows us to discover some of the important features which are often hidden in a network description of the system.},
  langid = {english},
  file = {/Users/david/Documents/pdf_library/A/Angel_Hyman_1970_Urban Velocity Fields.pdf}
}

